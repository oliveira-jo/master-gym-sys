@baseUrl = http://localhost:8080

### Save Student
POST {{baseUrl}}/alunos
Content-Type: application/json

{
  "name" : "João da Silva",
  "birthdate": "1995-08-15",
  "genre": "M",
  "phone": "48991645543",
  "email": "joao@email.com",
  "observations": "Aluno iniciante",
  "address": "Rua das Flores",
  "number": "123",
  "complement": "Apartamento 202",
  "city": "Criciúma",
  "state": "SC",
  "zipCode": "88802410"
}

### List Students
GET {{baseUrl}}/students

### List Students With pagination
GET {{baseUrl}}/students?page=0&size=10&sort=name,asc

### Find student by ID
GET {{baseUrl}}/students/1

### Update Student
PUT {{baseUrl}}/students/1
Content-Type: application/json

{
  "name" : "João da Silva Atualizado",
  "birthdate": "1995-08-15",
  "genre": "M",
  "phone": "48991645543",
  "email": "joao@email.com",
  "observations": "Aluno iniciante",
  "address": "Rua das Flores",
  "number": "123",
  "complement": "Apartamento 202",
  "city": "Criciúma",
  "state": "SC",
  "zipCode": "88802410"
}

### Delete Student
DELETE {{baseUrl}}/students/1

